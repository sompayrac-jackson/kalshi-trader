# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Kalshi API key ID (from your Kalshi account settings)
KALSHI_API_KEY=your-kalshi-api-key-id-here

# The Odds API key (get one at the-odds-api.com) — optional, arb scanner only
ODDS_API_KEY=your-odds-api-key-here

# Path to your RSA private key (default: private_key.pem in project root)
PRIVATE_KEY_PATH=private_key.pem

# Dashboard HTTP Basic Auth
# Set a strong password — anyone with access can trigger LIVE orders.
# Leave DASHBOARD_PASS empty to disable auth (local dev only, never in production).
DASHBOARD_USER=kalshi
DASHBOARD_PASS=change-me-to-a-strong-password

# Pushover push notifications (live trades only)
# Install the Pushover app, then get your User Key from pushover.net/dashboard
# Create an Application at pushover.net/apps/build to get an App Token
PUSHOVER_USER_KEY=your-pushover-user-key
PUSHOVER_APP_TOKEN=your-pushover-app-token
